                      name="SqlCommandParam"
                      UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor">select * from (select * from [dbo].[FactOnlineSales]) [refTable]
where [refTable].[ProductKey] = ?</property>
